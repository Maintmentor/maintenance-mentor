# 🔧 SETUP INSTRUCTIONS
# 1. Copy this file to .env: cp .env.example .env
# 2. Get your API key: https://app.supabase.com/project/kudlclzjfihbphehhiii/settings/api
# 3. Copy the "anon public" key (NOT service_role)
# 4. Paste it below
# 5. Save and restart: npm run dev

# ✅ Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://kudlclzjfihbphehhiii.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# 🤖 OpenAI (Optional - for AI features)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_key_here

# 💳 Stripe (Optional - for payments)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_key_here

# 📢 Slack (Optional - for notifications)
# Get from: https://api.slack.com/apps
SLACK_WEBHOOK_URL=your_slack_webhook_here

# 🔍 Need help? Run: ./fix-connection.sh
# Or open: setup-connection.html in your browser
